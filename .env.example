# Backend API (your friends' server)
BACKEND_URL=http://192.168.1.50:8080
BACKEND_API_KEY=
BACKEND_TIMEOUT_SECS=5

# PIR motion sensor GPIO pin (BCM numbering)
PIR_GPIO_PIN=17

# Button GPIO pin for cycling through stops (BCM). 0 = disabled.
# Wire: GPIO pin → button → GND (uses internal pull-up, active LOW)
BUTTON_GPIO_PIN=27

# LED GPIO pin for "display active" indicator (BCM). 0 = disabled.
LED_GPIO_PIN=22

# Seconds of no motion before display sleeps
IDLE_TIMEOUT_SECS=60

# How often to re-fetch departures while active (seconds)
POLL_INTERVAL_SECS=15

# Fallback stop name shown if backend omits stop_name
STOP_NAME=Bořislavka

# Max departure rows on display (OLED fits 4 with header)
MAX_DEPARTURES=4
